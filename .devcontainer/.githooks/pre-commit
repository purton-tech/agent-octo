#!/bin/bash

set -euo pipefail

format_result=0

for manifest in \
    crates/tool-runtime/Cargo.toml \
    crates/agent-runtime/Cargo.toml \
    crates/channels/Cargo.toml \
    crates/octo/Cargo.toml \
    crates/db/Cargo.toml
do
    if ! cargo fmt --manifest-path "$manifest" -- --check
    then
        format_result=1
    fi
done

if [[ ${format_result} -ne 0 ]] ; then
    cat <<\EOF
There are some code style issues, run 'cargo fmt' first.
EOF
    exit 1
fi

if ! cargo clippy --all-targets -- -D warnings
then
    echo "There are some clippy issues, run 'cargo clippy' first."
    exit 1
fi

exit 0
