[0.000, "o", "\r\u001b[7m        \"content\": \"{\\\"city\\\":\\\"London\\\",\\\"start_date\\\":\\\"2026-03-05\\\",\\\"end_date\\\":\\\"2026-03-11\\\",\\\"daily\\\":[{\\\"date\\\":\\\"2026-03-05\\\",\\\"average_temperature\\\":11.6,\\\"unit\\\":\\\"°C\\\"},{\\\"date\\\":\\\"2026-03-06\\\",\\\"average_temperatu\u001b[27m\u001b[7mr\u001b[27m\u001b[7me\\\":9.1,\\\"unit\\\":\\\"°C\\\"},{\\\"date\\\":\\\"2026-03-07\\\",\\\"average_temperature\\\":8.1,\\\"unit\\\":\\\"°C\\\"},{\\\"date\\\":\\\"2026-03-08\\\",\\\"average_temperature\\\":8.8,\\\"unit\\\":\\\"°C\\\"},{\\\"date\\\":\\\"2026-03-09\\\",\\\"average_temperature\\\":9.7,\\\"unit\u001b[27m\u001b[7m\\\u001b[27m\u001b[7m\":\\\"°C\\\"},{\\\"date\\\":\\\"2026-03-10\\\",\\\"average_temperature\\\":10.1,\\\"unit\\\":\\\"°C\\\"},{\\\"date\\\":\\\"2026-03-11\\\",\\\"average_temperature\\\":10.0,\\\"unit\\\":\\\"°C\\\"}]}\"\u0000\u001b[27m\r\n\r\u001b[7m      }\u001b[27m\r\n\r\u001b[7m    ],\u001b[27m\r\n\r\u001b[7m    \"tools\": [\u001b[27m\r\n\r\u001b[7m      {\u001b[27m\r\n\r\u001b[7m        \"type\": \"function\",\u001b[27m\r\n\r\u001b[7m        \"function\": {\u001b[27m\r\n\r\u001b[7m          \"name\": \"run_sandbox_code\",\u001b[27m\r\n\r\u001b[7m          \"description\": \"Run Python code in a sandbox to retrieve data and compute results.\",\u001b[27m\r\n\r\u001b[7m          \"parameters\": {\u001b[27m\r\n\r\u001b[7m            \"type\": \"object\",\u001b[27m\r\n"]
[0.000, "o", "\r\u001b[7m            \"properties\": {\u001b[27m\r\n\r\u001b[7m              \"code\": { \"type\": \"string\" }\u001b[27m\r\n"]
