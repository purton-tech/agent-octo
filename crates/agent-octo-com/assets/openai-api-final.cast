[0.979, "o", "curl https://api.openai.com/v1/chat/completions \\\r\n\r  -s \\\r\n\r  -H \"Content-Type: application/json\" \\\r\n\r  -H \"Authorization: Bearer $OPENAI_API_KEY\" \\\r\n\r  -d '{\r\n\r    \"model\": \"gpt-5\",\r\n\r    \"messages\": [\r\n\r\u001b[7m      {\u001b[27m\r\n\r\u001b[7m        \"role\": \"system\",\u001b[27m\r\n\r\u001b[7m        \"content\": \"If a question requires external data or calculations, call the run_sandbox_code tool instead of answering directly.\"\u001b[27m\r\n\r\u001b[7m      },\u001b[27m\r\n"]
