[0.000, "o", "\r\u001b[7m              \"arguments\": \"{\\\"code\\\":\\\"import requests, datetime, sys\\\\nfrom datetime import date, timedelta\\\\n\\\\n# Compute start and end dates: last 7 completed days (excluding today)\\\\ntoday = date.today()\\\\nstart_date = t\u001b[27m\u001b[7mo\u001b[27m\u001b[7mday - timedelta(days=7)\\\\nend_date = today - timedelta(days=1)\\\\n\\\\nlat, lon = 51.5072, -0.1276\\\\nurl = (\\\\n  \\\\\\\"https://archive-api.open-meteo.com/v1/archive\\\\\\\"\\\\n  f\\\\\\\"?latitude={lat}&longitude={lon}\\\\\\\"\\\\n  f\\\\\\\"&start\u001b[27m\u001b[7m_\u001b[27m\u001b[7mdate={start_date.isoformat()}&end_date={end_date.isoformat()}\\\\\\\"\\\\n  \\\\\\\"&daily=temperature_2m_mean&timezone=Europe%2FLondon\\\\\\\"\\\\n)\\\\n\\\\nresp = requests.get(url, timeout=30)\\\\nresp.raise_for_status()\\\\njs = resp.json()\\\\n\\\u001b[27m\u001b[7m\\\u001b[27m\u001b[7mndates = js.get('daily', {}).get('time', [])\\\\nmeans = js.get('daily', {}).get('temperature_2m_mean', [])\\\\n\\\\nresults = [\\\\n  {\\\\\\\"date\\\\\\\": d, \\\\\\\"avg_temp_c\\\\\\\": None if m is None else round(m,1)}\\\\n  for d, m in zip(date\u001b[27m\u001b[7ms\u001b[27m\u001b[7m, means)\\\\n]\\\\n\\\\nprint({\\\\\\\"location\\\\\\\":\\\\\\\"London, UK\\\\\\\",\\\\\\\"start_date\\\\\\\":start_date.isoformat(),\\\\\\\"end_date\\\\\\\":end_date.isoformat(),\\\\\\\"results\\\\\\\":results})\\\"}\"\u0000\u001b[27m\r\n\r\u001b[7m            }\u001b[27m\r\n\r\u001b[7m          }\u001b[27m\r\n\r\u001b[7m        ]\u001b[27m\r\n\r\u001b[7m      },\u001b[27m\r\n\r\u001b[7m      {\u001b[27m\r\n"]
